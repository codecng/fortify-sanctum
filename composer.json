{
  "name": "codecng/fortify-sanctum",
  "description": "A zero config laravel package to use fortify flavours in sanctum.",
  "keywords": [
    "laravel",
    "auth",
    "sanctum",
    "fortify",
    "fortify-sanctum"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Charles Paul",
      "email": "dev.charles15531@gmail.com"
    },
    {
      "name": "Christian Negron",
      "email": "cnegrondev@gmail.com"
    }
  ],
  "require": {
    "php": "^8.3|^8.4|^8.5",
    "laravel/fortify": "^1.21",
    "laravel/sanctum": "^4.0",
    "illuminate/support": "^10.0|^11.0|^12.0"
  },
  "autoload": {
    "psr-4": {
      "Devcharles\\FortifySanctum\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Devcharles\\FortifySanctum\\FortifySanctumServiceProvider"
      ]
    }
  }
}
